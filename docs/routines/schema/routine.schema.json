{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sulla.desktop/schemas/routine.schema.json",
  "title": "Sulla Routine Document",
  "description": "Schema for a Routine — the DAG document authored on the Sulla canvas. The same document shape is stored as JSONB in the Postgres `workflows.definition` column and is serialized as `routine.yaml` for export/import. Mirrors the `WorkflowDefinition` TypeScript interface in pkg/rancher-desktop/pages/editor/workflow/types.ts.",
  "type": "object",
  "required": [
    "id",
    "name",
    "description",
    "version",
    "createdAt",
    "updatedAt",
    "nodes",
    "edges"
  ],
  "additionalProperties": false,

  "properties": {
    "id": {
      "type": "string",
      "minLength": 1,
      "description": "Unique identifier for the routine. Typically 'workflow-<kebab-slug>' or 'routine-<kebab-slug>'."
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable display name."
    },
    "description": {
      "type": "string",
      "description": "What the routine does and when it runs. Read by the workflow registry + LLM."
    },
    "version": {
      "const": 1,
      "description": "Document schema version. Bump if the routine document shape changes in a breaking way."
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },

    "nodes": {
      "type": "array",
      "description": "The nodes on the canvas.",
      "items": { "$ref": "#/$defs/node" }
    },
    "edges": {
      "type": "array",
      "description": "Directed edges connecting nodes.",
      "items": { "$ref": "#/$defs/edge" }
    },
    "viewport": {
      "type": "object",
      "description": "Persisted pan/zoom of the canvas.",
      "required": ["x", "y", "zoom"],
      "additionalProperties": false,
      "properties": {
        "x":    { "type": "number" },
        "y":    { "type": "number" },
        "zoom": { "type": "number" }
      }
    }
  },

  "$defs": {
    "node": {
      "type": "object",
      "required": ["id", "type", "position", "data"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "const": "workflow",
          "description": "vue-flow node type. Always the literal string 'workflow' — per-node differentiation is on `data.subtype`."
        },
        "position": {
          "type": "object",
          "required": ["x", "y"],
          "additionalProperties": false,
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" }
          }
        },
        "data": { "$ref": "#/$defs/nodeData" }
      }
    },

    "nodeData": {
      "type": "object",
      "required": ["subtype", "category", "label", "config"],
      "additionalProperties": true,
      "description": "Persistent node data. `execution` state is runtime-only and MUST NOT appear in exports.",
      "properties": {
        "subtype": {
          "type": "string",
          "enum": [
            "calendar", "chat-app", "heartbeat", "schedule", "sulla-desktop", "workbench", "chat-completions",
            "agent", "integration-call", "tool-call", "orchestrator-prompt", "function",
            "router", "condition",
            "wait", "loop", "parallel", "merge", "sub-workflow",
            "user-input", "response", "transfer"
          ],
          "description": "Drawn from WorkflowNodeSubtype. `function` invokes a function at ~/sulla/functions/<slug>/ via the matching runtime container."
        },
        "category": {
          "type": "string",
          "enum": ["trigger", "agent", "routing", "flow-control", "io"]
        },
        "label": {
          "type": "string"
        },
        "config": {
          "type": "object",
          "description": "Per-subtype config. Shape depends on `subtype` — see the per-subtype config interfaces in pkg/rancher-desktop/pages/editor/workflow/types.ts (TriggerNodeConfig, AgentNodeConfig, FunctionNodeConfig, RouterNodeConfig, ...).",
          "additionalProperties": true
        }
      }
    },

    "edge": {
      "type": "object",
      "required": ["id", "source", "target"],
      "additionalProperties": false,
      "properties": {
        "id":           { "type": "string", "minLength": 1 },
        "source":       { "type": "string", "minLength": 1 },
        "target":       { "type": "string", "minLength": 1 },
        "sourceHandle": { "type": "string" },
        "targetHandle": { "type": "string" },
        "label":        { "type": "string" },
        "animated":     { "type": "boolean" }
      }
    }
  }
}
