{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sulla.desktop/schemas/function.schema.json",
  "title": "Sulla Function Manifest",
  "description": "Schema for function.yaml — the manifest for a custom, one-off function. Functions are the lightweight counterpart to routines: same runtime containers, same invocation shape, but no version pinning, no publish step, always runs HEAD from disk.",
  "type": "object",
  "required": ["apiVersion", "kind", "id", "name", "description", "schemaversion", "spec"],
  "additionalProperties": false,

  "properties": {
    "apiVersion": { "type": "string", "const": "sulla/v1" },
    "kind":       { "type": "string", "const": "Function" },

    "id": {
      "type": "string",
      "pattern": "^function-[a-z0-9][a-z0-9-]*[a-z0-9]$",
      "description": "Unique identifier. Prefix: 'function-'."
    },
    "name":        { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },

    "schemaversion": {
      "type": "integer",
      "minimum": 1,
      "description": "Format version of the function schema."
    },

    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$",
      "description": "Must match the directory name and the id suffix."
    },

    "tags":        { "type": "array", "items": { "type": "string" } },
    "enabled":     { "type": "boolean", "default": true },
    "author":      { "type": "string" },
    "createdAt":   { "type": "string", "format": "date-time" },
    "updatedAt":   { "type": "string", "format": "date-time" },

    "spec": {
      "type": "object",
      "required": ["runtime", "entrypoint"],
      "additionalProperties": false,
      "properties": {
        "runtime": {
          "type": "string",
          "enum": ["python", "node", "shell", "agent"]
        },
        "entrypoint": {
          "type": "string",
          "description": "Path to entrypoint relative to function root. Python/Node: 'main.py::handler'. Shell: 'main.sh'. Agent: 'prompt.md'."
        },
        "compatibility": { "type": "string" },

        "inputs": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/ioField" }
        },
        "outputs": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/ioField" }
        },

        "permissions": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "network": { "type": "array", "items": { "type": "string" } },
            "env":     { "type": "array", "items": { "type": "string" } },
            "filesystem": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["path", "mode"],
                "properties": {
                  "path": { "type": "string" },
                  "mode": { "type": "string", "enum": ["read", "write"] }
                }
              }
            },
            "secrets": { "type": "array", "items": { "type": "string" } }
          }
        },

        "timeout": {
          "type": "string",
          "pattern": "^\\d+(ms|s|m|h)$"
        },

        "resources": { "type": "array", "items": { "type": "string" } },
        "templates": { "type": "array", "items": { "type": "string" } }
      }
    }
  },

  "$defs": {
    "ioField": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": true,
      "properties": {
        "type": {
          "oneOf": [
            { "type": "string", "enum": ["string", "number", "integer", "boolean", "object", "array", "null"] },
            { "type": "array",  "items": { "type": "string", "enum": ["string", "number", "integer", "boolean", "object", "array", "null"] } }
          ]
        },
        "description": { "type": "string" },
        "required":    { "type": "boolean", "default": false },
        "default":     {},
        "enum":        { "type": "array" },
        "pattern":     { "type": "string" },
        "format":      { "type": "string" },
        "minimum":     { "type": "number" },
        "maximum":     { "type": "number" },
        "items":       { "$ref": "#/$defs/ioField" },
        "properties": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/ioField" }
        }
      }
    }
  }
}
