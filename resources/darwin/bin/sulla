#!/bin/sh
# sulla — unified CLI for Sulla Desktop
#
# Proxy call:    sulla <account_id>/<slug> '<json>'
# Tool call:     sulla <category>/<tool> '<json>'
# MCP call:      sulla <account_id>/mcp/<tool> '<json>'
# Bare tool:     sulla <tool_name> '<json>'

# Load defaults from environment file; existing env vars win.
if [ -f /etc/sulla-env ]; then
  [ -z "$SULLA_API_TOKEN" ] || _existing_token="$SULLA_API_TOKEN"
  [ -z "$SULLA_HOST" ]      || _existing_host="$SULLA_HOST"
  . /etc/sulla-env
  [ -n "$_existing_token" ] && SULLA_API_TOKEN="$_existing_token"
  [ -n "$_existing_host" ]  && SULLA_HOST="$_existing_host"
  unset _existing_token _existing_host
  export SULLA_API_TOKEN SULLA_HOST
fi

SOCKET="/tmp/sulla-tools.sock"
SULLA_HOST="${SULLA_HOST:-host.lima.internal}"
FIRST="$1"
BODY="$2"

# Known internal tool categories. Must stay in sync with agent/tools/registry.ts
# `categoriesList` so `sulla <category>/<tool>` routes to /v1/tools/internal
# instead of falling through as a proxy call.
TOOL_CATEGORIES="agents|applescript|bridge|browser|calendar|capture|docker|extensions|fs|function|github|integrations|kubectl|lima|marketplace|memory|meta|mobile|notify|observation|pg|projects|rdctl|redis|skills|slack|ui|vault|workflow|workspace"

# ── Help & discovery ─────────────────────────────────────────────
# sulla --help | sulla -h | sulla help | sulla (no args) — query the backend
# for the live category list so new categories surface without needing a
# CLI rebuild. Fall back to the hardcoded text below if the backend is
# unreachable (e.g. during first-run or when Sulla Desktop isn't booted).
if [ -z "$FIRST" ] || [ "$FIRST" = "--help" ] || [ "$FIRST" = "-h" ] || [ "$FIRST" = "help" ]; then
  _help_url="/v1/tools/help"
  if [ -S "$SOCKET" ]; then
    _live=$(curl -s --max-time 2 --unix-socket "$SOCKET" \
      ${SULLA_API_TOKEN:+-H "Authorization: Bearer $SULLA_API_TOKEN"} \
      "http://localhost${_help_url}" 2>/dev/null)
  else
    _live=$(curl -s --max-time 2 \
      ${SULLA_API_TOKEN:+-H "Authorization: Bearer $SULLA_API_TOKEN"} \
      "http://${SULLA_HOST}:3000${_help_url}" 2>/dev/null)
  fi
  if [ -n "$_live" ] && printf '%s' "$_live" | grep -q "Categories"; then
    printf '%s\n' "$_live"
    printf '\nRun "sulla <category> --help" or "sulla <category>" to list tools in a category.\n'
    exit 0
  fi
  cat <<'HELP'
sulla — unified CLI for Sulla Desktop

Usage:
  sulla <category>/<tool> '<json>'           # tool call
  sulla <category> --help                    # list tools in a category
  sulla <account_id>/<slug> '<json>'         # proxy call
  sulla <account>/mcp/<tool> '<json>'        # MCP tool
  sulla <tool_name> '<json>'                 # bare tool

Flags:
  --help, -h    Show this help or category-specific help

Categories (live list unavailable — showing fallback):
  meta              Tools for browsing available tools, installing skills, and meta management
  agents            Sub-agent spawning and job management
  applescript       Execute AppleScript to control macOS apps (Calendar, Mail, Finder, etc.)
  bridge            Bidirectional communication bridge between heartbeat and frontend
  browser           Open/close tabs, read page content, click + fill forms, screenshot, exec JS, cookies, history
  calendar          Calendar event management
  capture           Capture Studio control: teleprompter, microphone, speaker loopback, screenshots, recorder
  docker            Docker container management
  extensions        Extension marketplace — browse, install, uninstall Docker Compose stacks
  function          Custom function runner — list and invoke ~/sulla/functions/
  github            GitHub repository management
  integrations      Check integration status + retrieve integration credentials
  kubectl           Kubernetes cluster management
  lima              Lima VM instance management
  marketplace       Search / download / scaffold / validate / publish community artifacts
  memory            Memory-recall tool discovery + catalog browsing
  mobile            Sulla Mobile companion — read calls, leads, and messages from the AI receptionist
  notify            Send desktop notifications to alert the user
  observation       Observational memory + write_file to home
  pg                PostgreSQL database queries
  projects          Project PRDs — search, load, create, update, delete
  rdctl             Sulla Desktop / rdctl management commands
  redis             Redis key/value store operations
  skills            Search, load, and create reusable skill files
  slack             Slack messaging and reactions
  ui                Open Sulla Desktop views (marketplace, vault, routines) from chat
  vault             Credential vault — list accounts, read/set secrets
  workflow          Workflow management — execute, validate, import, manage definitions
  workspace         Manage workspace folders in the Rancher Desktop data directory

Run "sulla <category> --help" to see tools in a category.
Run "sulla vault/list_accounts '{}'" to discover proxy accounts.
HELP
  exit 0
# sulla <category> --help  (e.g. sulla bridge --help)
elif [ "$BODY" = "--help" ] || [ "$BODY" = "-h" ]; then
  METHOD="GET"
  URL="/v1/tools/help/${FIRST}"
  BODY=""
else
  METHOD="POST"

  if [ -z "$BODY" ]; then
    BODY='{}'
  fi

  case "$FIRST" in
    */mcp/*)
      # MCP tool: account_id/mcp/tool_name
      ACCOUNT="${FIRST%%/mcp/*}"
      TOOL="${FIRST##*/mcp/}"
      URL="/v1/tools/${ACCOUNT}/mcp/${TOOL}/call"
      ;;
    */*)
      # Has a slash — check if it's a tool category or a proxy call
      PART1="${FIRST%%/*}"
      PART2="${FIRST#*/}"
      # Blocked from CLI — native agent tool only, prevents circular tool calling
      if [ "$PART1/$PART2" = "meta/exec" ]; then
        echo '{"error":"Blocked: do not call sulla CLI for this function. Preventing circular tool calling. Use the native exec tool instead."}' >&2
        exit 1
      fi
      if echo "$PART1" | grep -qE "^($TOOL_CATEGORIES)$"; then
        # Tool call: category/tool_name
        URL="/v1/tools/internal/${PART1}/${PART2}/call"
      else
        # Proxy call: account_id/slug
        URL="/v1/proxy/${PART1}/${PART2}"
      fi
      ;;
    *)
      # Bare name with no slash — check if it's a category (→ help) or a bare tool
      if echo "$FIRST" | grep -qE "^($TOOL_CATEGORIES)$"; then
        METHOD="GET"
        URL="/v1/tools/help/${FIRST}"
        BODY=""
      else
        # Bare tool name — route as internal with integrations as default slug
        URL="/v1/tools/internal/integrations/${FIRST}/call"
      fi
      ;;
  esac
fi

# ── Execute ──────────────────────────────────────────────────────
if [ "$METHOD" = "GET" ]; then
  if [ -S "$SOCKET" ]; then
    if [ -n "$SULLA_API_TOKEN" ]; then
      exec curl -s --unix-socket "$SOCKET" -H "Authorization: Bearer $SULLA_API_TOKEN" "http://localhost${URL}"
    else
      exec curl -s --unix-socket "$SOCKET" "http://localhost${URL}"
    fi
  else
    if [ -n "$SULLA_API_TOKEN" ]; then
      exec curl -s -H "Authorization: Bearer $SULLA_API_TOKEN" "http://${SULLA_HOST}:3000${URL}"
    else
      exec curl -s "http://${SULLA_HOST}:3000${URL}"
    fi
  fi
else
  if [ -S "$SOCKET" ]; then
    if [ -n "$SULLA_API_TOKEN" ]; then
      exec curl -s --unix-socket "$SOCKET" -X POST "http://localhost${URL}" \
        -H "Content-Type: application/json" \
        -H "Authorization: Bearer $SULLA_API_TOKEN" \
        -d "$BODY"
    else
      exec curl -s --unix-socket "$SOCKET" -X POST "http://localhost${URL}" \
        -H "Content-Type: application/json" \
        -d "$BODY"
    fi
  else
    if [ -n "$SULLA_API_TOKEN" ]; then
      exec curl -s -X POST "http://${SULLA_HOST}:3000${URL}" \
        -H "Content-Type: application/json" \
        -H "Authorization: Bearer $SULLA_API_TOKEN" \
        -d "$BODY"
    else
      exec curl -s -X POST "http://${SULLA_HOST}:3000${URL}" \
        -H "Content-Type: application/json" \
        -d "$BODY"
    fi
  fi
fi
