#!/bin/sh
# sulla — unified CLI for Sulla Desktop
#
# Proxy call:    sulla <account_id>/<slug> '<json>'
# Tool call:     sulla <category>/<tool> '<json>'
# MCP call:      sulla <account_id>/mcp/<tool> '<json>'
# Bare tool:     sulla <tool_name> '<json>'

# Load defaults from environment file; existing env vars win.
if [ -f /etc/sulla-env ]; then
  [ -z "$SULLA_API_TOKEN" ] || _existing_token="$SULLA_API_TOKEN"
  [ -z "$SULLA_HOST" ]      || _existing_host="$SULLA_HOST"
  . /etc/sulla-env
  [ -n "$_existing_token" ] && SULLA_API_TOKEN="$_existing_token"
  [ -n "$_existing_host" ]  && SULLA_HOST="$_existing_host"
  unset _existing_token _existing_host
  export SULLA_API_TOKEN SULLA_HOST
fi

SOCKET="/tmp/sulla-tools.sock"
SULLA_HOST="${SULLA_HOST:-host.lima.internal}"
FIRST="$1"
BODY="$2"

# Known internal tool categories
TOOL_CATEGORIES="meta|docker|github|playwright|chrome|rdctl|redis|pg|n8n|slack|kubectl|lima|calendar|extensions|vault|agents|bridge|computer-use"

# ── Help & discovery ─────────────────────────────────────────────
# sulla --help | sulla -h | sulla help | sulla (no args)
if [ -z "$FIRST" ] || [ "$FIRST" = "--help" ] || [ "$FIRST" = "-h" ] || [ "$FIRST" = "help" ]; then
  cat <<'HELP'
sulla — unified CLI for Sulla Desktop

Usage:
  sulla <category>/<tool> '<json>'           # tool call
  sulla <account_id>/<slug> '<json>'         # proxy call
  sulla <account>/mcp/<tool> '<json>'        # MCP tool
  sulla <tool_name> '<json>'                 # bare tool

Flags:
  --help, -h    Show this help or category-specific help

Categories:
  meta              Tools for browsing available tools, installing skills, and meta management
  bridge            Bidirectional communication bridge between heartbeat and frontend
  calendar          Calendar event management
  chrome            Browser extension-style APIs — history, notifications, storage, cookies
  computer-use      Visual computer use — screenshot-based interaction
  docker            Docker container management
  extensions        Extension marketplace — browse, install, uninstall Docker Compose stacks
  github            GitHub repository management
  kubectl           Kubernetes cluster management
  lima              Lima VM instance management
  pg                PostgreSQL database queries
  playwright        Browser automation suite — DOM tools, visual tools, exec_in_page
  rdctl             Sulla Desktop / rdctl management commands
  redis             Redis key/value store operations
  slack             Slack messaging and reactions
  vault             Credential vault — list accounts, read/set secrets

Run "sulla <category> --help" to see tools in a category.
Run "sulla vault/list_accounts '{}'" to discover proxy accounts.
HELP
  exit 0
# sulla <category> --help  (e.g. sulla bridge --help)
elif [ "$BODY" = "--help" ] || [ "$BODY" = "-h" ]; then
  METHOD="GET"
  URL="/v1/tools/help/${FIRST}"
  BODY=""
else
  METHOD="POST"

  if [ -z "$BODY" ]; then
    BODY='{}'
  fi

  case "$FIRST" in
    */mcp/*)
      # MCP tool: account_id/mcp/tool_name
      ACCOUNT="${FIRST%%/mcp/*}"
      TOOL="${FIRST##*/mcp/}"
      URL="/v1/tools/${ACCOUNT}/mcp/${TOOL}/call"
      ;;
    */*)
      # Has a slash — check if it's a tool category or a proxy call
      PART1="${FIRST%%/*}"
      PART2="${FIRST#*/}"
      if echo "$PART1" | grep -qE "^($TOOL_CATEGORIES)$"; then
        # Tool call: category/tool_name
        URL="/v1/tools/internal/${PART1}/${PART2}/call"
      else
        # Proxy call: account_id/slug
        URL="/v1/proxy/${PART1}/${PART2}"
      fi
      ;;
    *)
      # Bare name with no slash — check if it's a category (→ help) or a bare tool
      if echo "$FIRST" | grep -qE "^($TOOL_CATEGORIES)$"; then
        METHOD="GET"
        URL="/v1/tools/help/${FIRST}"
        BODY=""
      else
        # Bare tool name — route as internal with integrations as default slug
        URL="/v1/tools/internal/integrations/${FIRST}/call"
      fi
      ;;
  esac
fi

# ── Execute ──────────────────────────────────────────────────────
if [ "$METHOD" = "GET" ]; then
  if [ -S "$SOCKET" ]; then
    if [ -n "$SULLA_API_TOKEN" ]; then
      exec curl -s --unix-socket "$SOCKET" -H "Authorization: Bearer $SULLA_API_TOKEN" "http://localhost${URL}"
    else
      exec curl -s --unix-socket "$SOCKET" "http://localhost${URL}"
    fi
  else
    if [ -n "$SULLA_API_TOKEN" ]; then
      exec curl -s -H "Authorization: Bearer $SULLA_API_TOKEN" "http://${SULLA_HOST}:3000${URL}"
    else
      exec curl -s "http://${SULLA_HOST}:3000${URL}"
    fi
  fi
else
  if [ -S "$SOCKET" ]; then
    if [ -n "$SULLA_API_TOKEN" ]; then
      exec curl -s --unix-socket "$SOCKET" -X POST "http://localhost${URL}" \
        -H "Content-Type: application/json" \
        -H "Authorization: Bearer $SULLA_API_TOKEN" \
        -d "$BODY"
    else
      exec curl -s --unix-socket "$SOCKET" -X POST "http://localhost${URL}" \
        -H "Content-Type: application/json" \
        -d "$BODY"
    fi
  else
    if [ -n "$SULLA_API_TOKEN" ]; then
      exec curl -s -X POST "http://${SULLA_HOST}:3000${URL}" \
        -H "Content-Type: application/json" \
        -H "Authorization: Bearer $SULLA_API_TOKEN" \
        -d "$BODY"
    else
      exec curl -s -X POST "http://${SULLA_HOST}:3000${URL}" \
        -H "Content-Type: application/json" \
        -d "$BODY"
    fi
  fi
fi
